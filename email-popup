<!-- EMAIL CAPTURE POPUP -->
<!-- Add this just before </body> in index.html -->

<div id="email-popup" class="email-popup">
  <div class="email-popup-overlay" onclick="closeEmailPopup()"></div>
  <div class="email-popup-content">
    <button class="email-popup-close" onclick="closeEmailPopup()">×</button>
    <div class="email-popup-left">
      <img src="images/mia.png" alt="Mia" id="popup-img">
    </div>
    <div class="email-popup-right">
      <h3>She's waiting for you.</h3>
      <p>Get early access to Mia & Jess. Plus: exclusive late-night content, new features first, and a free intimate session when we launch.</p>
      <form id="email-form" onsubmit="submitEmail(event)">
        <input type="email" id="email-input" placeholder="your@email.com" required>
        <button type="submit" class="btn-primary">Get Early Access →</button>
      </form>
      <p class="email-popup-note">No spam. She hates spam too. Unsubscribe anytime.</p>
      <div class="email-popup-social">
        <span>Or start now:</span>
        <button class="btn-secondary" onclick="closeEmailPopup(); startChat('mia')">Chat with Mia Free</button>
      </div>
    </div>
  </div>
</div>

<style>
.email-popup {
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1000;
  align-items: center;
  justify-content: center;
}

.email-popup.active { display: flex; }

.email-popup-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(8px);
}

.email-popup-content {
  position: relative;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 24px;
  max-width: 700px;
  width: 90%;
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  overflow: hidden;
  animation: popupIn 0.4s ease;
}

@keyframes popupIn {
  from { opacity: 0; transform: scale(0.9) translateY(20px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.email-popup-close {
  position: absolute;
  top: 1rem; right: 1rem;
  background: none;
  border: none;
  color: var(--text-muted);
  font-size: 1.5rem;
  cursor: pointer;
  z-index: 10;
  width: 36px; height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.email-popup-close:hover {
  background: rgba(255,255,255,0.1);
  color: var(--text-primary);
}

.email-popup-left {
  position: relative;
  min-height: 300px;
}

.email-popup-left img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  position: absolute;
  top: 0; left: 0;
}

.email-popup-left::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to right, transparent, var(--bg-card));
}

.email-popup-right {
  padding: 2.5rem;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.email-popup-right h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.8rem;
  margin-bottom: 0.75rem;
}

.email-popup-right p {
  color: var(--text-secondary);
  font-size: 0.95rem;
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

#email-form {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

#email-input {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 0.9rem 1rem;
  color: var(--text-primary);
  font-size: 0.95rem;
  font-family: inherit;
  outline: none;
  transition: border-color 0.3s;
}

#email-input:focus {
  border-color: var(--accent);
}

#email-input::placeholder {
  color: var(--text-muted);
}

.email-popup-note {
  font-size: 0.75rem !important;
  color: var(--text-muted) !important;
  margin-bottom: 1.5rem !important;
}

.email-popup-social {
  border-top: 1px solid var(--border);
  padding-top: 1rem;
}

.email-popup-social span {
  display: block;
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-bottom: 0.5rem;
}

.email-popup-social button {
  width: 100%;
}

/* Success state */
.email-popup-success {
  text-align: center;
  padding: 2rem;
}

.email-popup-success h3 {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  margin-bottom: 0.5rem;
}

.email-popup-success p {
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}

@media (max-width: 640px) {
  .email-popup-content {
    grid-template-columns: 1fr;
    max-width: 400px;
  }
  .email-popup-left {
    min-height: 180px;
  }
  .email-popup-left::after {
    background: linear-gradient(to bottom, transparent, var(--bg-card));
  }
}
</style>

<script>
// Email Popup Logic
function showEmailPopup(delay = 15000) {
  setTimeout(() => {
    // Only show if not already submitted
    if(!localStorage.getItem('glimr_email_submitted')) {
      document.getElementById('email-popup').classList.add('active');
    }
  }, delay);
}

function closeEmailPopup() {
  document.getElementById('email-popup').classList.remove('active');
  localStorage.setItem('glimr_popup_closed', Date.now());
}

function submitEmail(e) {
  e.preventDefault();
  const email = document.getElementById('email-input').value;

  // Store locally (replace with your backend API)
  let emails = JSON.parse(localStorage.getItem('glimr_emails') || '[]');
  emails.push({ email, date: new Date().toISOString(), source: 'popup' });
  localStorage.setItem('glimr_emails', JSON.stringify(emails));
  localStorage.setItem('glimr_email_submitted', 'true');

  // Show success
  const content = document.querySelector('.email-popup-content');
  content.innerHTML = `
    <div class="email-popup-success" style="grid-column: 1 / -1; padding: 3rem;">
      <div style="font-size: 3rem; margin-bottom: 1rem;">💌</div>
      <h3>You're in.</h3>
      <p>We'll message you when she's ready. In the meantime... want to chat now?</p>
      <button class="btn-primary" onclick="closeEmailPopup(); startChat('mia')" style="margin-bottom: 0.5rem;">Chat with Mia Now</button>
      <button class="btn-secondary" onclick="closeEmailPopup()">Maybe Later</button>
    </div>
  `;

  // Also send to your backend
  // fetch('/api/waitlist', { method: 'POST', body: JSON.stringify({ email }) });
}

// Show popup on scroll (after 50% of page) or after 15 seconds
let popupShown = false;
window.addEventListener('scroll', () => {
  if(!popupShown && window.scrollY > document.body.scrollHeight * 0.4) {
    popupShown = true;
    showEmailPopup(0);
  }
});

// Also show after 15 seconds
showEmailPopup(15000);

// Exit intent popup
document.addEventListener('mouseleave', (e) => {
  if(e.clientY < 10 && !localStorage.getItem('glimr_email_submitted') && !localStorage.getItem('glimr_exit_shown')) {
    localStorage.setItem('glimr_exit_shown', 'true');
    document.getElementById('email-popup').classList.add('active');
    document.querySelector('.email-popup-right h3').textContent = "Wait. Don't leave yet.";
    document.querySelector('.email-popup-right p').textContent = "She's right here. One message. That's all it takes. Try her free. No signup. No credit card.";
  }
});
</script>
